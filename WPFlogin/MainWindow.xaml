<Window x:Class="WPFlogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFlogin"
        mc:Ignorable="d"
        Title="Bejelentkezés" Height="433" Width="900" Background="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="ÜDVÖZLÜNK A RENDSZERBEN!" FontSize="34" FontWeight="Bold" Foreground="#0B2A88"
                   HorizontalAlignment="Center" Margin="0,6,0,18" />

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <!-- Left: coin-like image with shadow -->
            <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <!-- Middle: labels and inputs -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,8,0,0" Width="420" Height="134">
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Width="120" Text="Felhasználónév:" VerticalAlignment="Center" />
                    <TextBox Name="UsernameTextBox" Width="300" Height="28" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Width="120" Text="Jelszó:" VerticalAlignment="Center" />
                    <PasswordBox Name="PasswordBox" Width="300" Height="28" />
                </StackPanel>

                <CheckBox Content="Megjegyzem a belépést" Margin="120,12,0,0" RenderTransformOrigin="0.513,0.465" Height="26" />
            </StackPanel>

            <!-- Right: buttons -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,18,0,0">
                <Button Content="BEJELENTKEZÉS" Width="150" Height="48" Click="Button_Click" Margin="0,0,0,10">
                    <Button.Background>
                        <SolidColorBrush Color="#2EB82E" />
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White" />
                    </Button.Foreground>
                    <Button.FontWeight>Bold</Button.FontWeight>
                </Button>

                <Button Content="MÉGSEMM" Width="150" Height="40" Click="Button_Click_1" Background="#D3D3D3" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Slider.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Slider"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <StackPanel Margin="20">
        <Slider x:Name="slErtek" Minimum="0" Maximum="100" Value="50"
                TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="slErtek_ValueChanged"/>
        <TextBlock x:Name="txtErtek" Text="50" FontSize="20" HorizontalAlignment="Center" Margin="0,15,0,0"/>
    </StackPanel>

</Window>

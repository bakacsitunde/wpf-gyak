<Window x:Class="ComboBox_SelectionChanged.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComboBox_SelectionChanged"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <ComboBox x:Name="cbNyelvek" Width="200" SelectedIndex="0" SelectionChanged="cbNyelvek_SelectionChanged">
            <ComboBoxItem Content="C#"/>
            <ComboBoxItem Content="Python"/>
            <ComboBoxItem Content="JavaScript"/>
            <ComboBoxItem Content="Java"/>
        </ComboBox>
        <TextBlock x:Name="txtValasztott" Margin="0,20,0,0" FontSize="16"/>
    </StackPanel>

</Window>

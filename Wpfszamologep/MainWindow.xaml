<Window x:Class="Wpfszamologep.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpfszamologep"
        mc:Ignorable="d"
        Title="MainWindow" Height="390" Width="350">
    <Grid ShowGridLines="False">
        <!-- Sor definíciók: Display + 5 sor gombok -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Display sor -->
            <RowDefinition Height="*"/>
            <!-- MC MR M+ M- -->
            <RowDefinition Height="*"/>
            <!-- 1 2 3 + -->
            <RowDefinition Height="*"/>
            <!-- 4 5 6 - -->
            <RowDefinition Height="*"/>
            <!-- 7 8 9 * -->
            <RowDefinition Height="*"/>
            <!-- 0 . = / -->
        </Grid.RowDefinitions>

        <!-- Oszlop definíciók: 4 egyenlő szélességű -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- DISPLAY (1. sor, mind 4 oszlop) -->
        <TextBox x:Name="display" 
                 Grid.Row="0" Grid.ColumnSpan="4"
                 FontSize="24" FontWeight="Bold"
                 Text="0" IsReadOnly="True"
                 VerticalContentAlignment="Center"
                 Padding="10"/>

        <!-- 1. gombsor: MC MR M+ M- -->
        <Button x:Name="btnC" Grid.Row="1" Grid.Column="0" Content="C" Margin="1" Click="Button_Click_Operation"/>
        <Button x:Name="btnNegyzet" Grid.Row="1" Grid.Column="1" Content="x&#178;" Margin="1" Click="Button_Click_Operation"/>
        <Button x:Name="btnReciprok" Grid.Row="1" Grid.Column="2" Content="&#x215F;x" Margin="1" Click="Button_Click_Operation"/>
        <Button x:Name="btnOsztas" Grid.Row="1" Grid.Column="3" Content="÷" Margin="1" Click="Button_Click_Operation"/>

        <!-- 2. gombsor: 1 2 3 + -->
        <Button x:Name="btn1" Grid.Row="2" Grid.Column="0" Content="1" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn2" Grid.Row="2" Grid.Column="1" Content="2" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn3" Grid.Row="2" Grid.Column="2" Content="3" Margin="1" Click="Button_Click"/>
        <Button x:Name="btnPlus" Grid.Row="2" Grid.Column="3" Content="+" Margin="1" Click="Button_Click_Operation"/>

        <!-- 3. gombsor: 4 5 6 - -->
        <Button x:Name="btn4" Grid.Row="3" Grid.Column="0" Content="4" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn5" Grid.Row="3" Grid.Column="1" Content="5" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn6" Grid.Row="3" Grid.Column="2" Content="6" Margin="1" Click="Button_Click"/>
        <Button x:Name="btnMinusz" Grid.Row="3" Grid.Column="3" Content="-" Margin="1" Click="Button_Click_Operation"/>

        <!-- 4. gombsor: 7 8 9 * -->
        <Button x:Name="btn7" Grid.Row="4" Grid.Column="0" Content="7" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn8" Grid.Row="4" Grid.Column="1" Content="8" Margin="1" Click="Button_Click"/>
        <Button x:Name="btn9" Grid.Row="4" Grid.Column="2" Content="9" Margin="1" Click="Button_Click"/>
        <Button x:Name="btnSzorzo" Grid.Row="4" Grid.Column="3" Content="×" Margin="1" Click="Button_Click_Operation"/>

        <!-- 5. gombsor: 0 . = / (0 dupla széles) -->
        <Button x:Name="btn0" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                Content="0" Margin="1" Click="Button_Click"/>
        <Button x:Name="btnPont" Grid.Row="5" Grid.Column="2" Content="," Margin="1" Click="Button_Click"/>
        <Button x:Name="btnEgyenlo" Grid.Row="5" Grid.Column="3" Content="=" Margin="1" Click="Button_Click_Operation" Background="LightGreen"/>

    </Grid>

</Window>
